# ═══════════════════════════════════════════════════════════════════════════════
# MODO DE EJECUCIÓN: 'local' o 'cloud'
# ═══════════════════════════════════════════════════════════════════════════════
# - local  → Usa Qdrant local (Docker), Ollama local para embeddings y LLM
# - cloud  → Usa Qdrant Cloud, Google Gemini / OpenRouter para embeddings y LLM
EXECUTION_MODE=cloud

# ─── API Keys (Obligatorio para Gemini/OpenRouter, modo cloud) ───────────────
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# ─── OpenRouter ──────────────────────────────────────────────────────────
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=http://localhost:8501
OPENROUTER_X_TITLE=TFM-AgriBot

# ─── Modelos por Defecto ─────────────────────────────────────────────────
DEFAULT_PROVIDER=gemini
DEFAULT_MODEL_OPENROUTER=openai/gpt-oss-120b:free
DEFAULT_MODEL_GOOGLE=gemini-3-flash-preview

# ─── Ollama (LLM Local) ─────────────────────────────────────────────────
# Modelo por defecto para Ollama (ligero, ~1.9 GB)
# Opciones recomendadas:
#   qwen2.5:3b   - 1.9 GB - Excelente relación calidad/tamaño
#   qwen2.5:7b   - 4.7 GB - Más potente, requiere más RAM
#   phi3:mini    - 2.3 GB - Buen razonamiento
#   gemma2:2b    - 1.6 GB - Ultra-ligero
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_OLLAMA_MODEL=qwen2.5:3b

# ─── Qdrant LOCAL (Base Vectorial On-Premise) ───────────────────────────
QDRANT_LOCAL_URL=http://localhost:6333

# ─── Qdrant CLOUD (Base Vectorial en la Nube) ───────────────────────────
QDRANT_CLOUD_URL=https://tu-cluster.cloud.qdrant.io:6333
QDRANT_CLOUD_API_KEY=

# ─── Embeddings ──────────────────────────────────────────────────────────
# En modo 'local': usa Ollama (qwen3-embedding, 1024d) — 100% local
# En modo 'cloud' y provider 'gemini': usa Gemini (gemini-embedding-001, 3072d) — requiere GOOGLE_API_KEY
# En modo 'cloud' y provider 'ollama': usa Ollama (qwen3-embedding, 1024d) pero guarda en Cloud
DEFAULT_EMBEDDING_PROVIDER=ollama
DEFAULT_EMBEDDING_MODEL_CLOUD=gemini-embedding-001
DEFAULT_EMBEDDING_MODEL_LOCAL=qwen3-embedding
