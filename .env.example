# ─── API Keys (Obligatorio para Gemini/OpenRouter) ───────────────────────
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# ─── OpenRouter ──────────────────────────────────────────────────────────
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=http://localhost:8501
OPENROUTER_X_TITLE=TFM-AgriBot

# ─── Modelos por Defecto ─────────────────────────────────────────────────
DEFAULT_PROVIDER=gemini
DEFAULT_MODEL_OPENROUTER=openai/gpt-oss-120b:free
DEFAULT_MODEL_GOOGLE=gemini-3-flash-preview

# ─── Ollama (LLM Local) ─────────────────────────────────────────────────
# Modelo por defecto para Ollama (ligero, ~1.9 GB)
# Opciones recomendadas:
#   qwen2.5:3b   - 1.9 GB - Excelente relación calidad/tamaño
#   qwen2.5:7b   - 4.7 GB - Más potente, requiere más RAM
#   phi3:mini    - 2.3 GB - Buen razonamiento
#   gemma2:2b    - 1.6 GB - Ultra-ligero
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_OLLAMA_MODEL=qwen2.5:3b

# ─── Qdrant (Base Vectorial) ────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# ─── Embeddings ──────────────────────────────────────────────────────────
# Siempre usa Ollama (nomic-embed-text, 768d) — 100% local, sin cuota
# Cambiar a 'gemini' si tienes GOOGLE_API_KEY con cuota disponible
DEFAULT_EMBEDDING_PROVIDER=ollama
DEFAULT_EMBEDDING_MODEL=models/text-embedding-004
